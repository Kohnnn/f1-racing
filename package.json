{
  "name": "f1-racing",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "npm run sync:models && npm run generate:sample && npm run refresh:showcase:replay && npm run dev -w @f1-racing/web",
    "build": "npm run sync:models && npm run generate:sample && npm run refresh:showcase:replay && npm run next:build -w @f1-racing/web",
    "build:pages": "npm run sync:models && npm run generate:sample && npm run refresh:showcase:replay && npm run next:build -w @f1-racing/web",
    "generate:sample": "node pipeline/export/src/generate-sample-data.mjs",
    "sync:models": "node pipeline/export/src/sync-web-models.mjs",
    "split:replay": "node pipeline/export/src/split-replay-packs.mjs",
    "api:dev": "python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8080",
    "api:start": "python -m uvicorn backend.main:app --host 0.0.0.0 --port 8080",
    "check:data": "node pipeline/export/src/generate-sample-data.mjs --check",
    "init:openfoam:local": "node pipeline/openfoam/src/init-openfoam-local.mjs",
    "build:openfoam:overlay": "node pipeline/openfoam/src/build-openfoam-overlay-pack.mjs",
    "apply:openfoam:inputs": "node pipeline/openfoam/src/apply-openfoam-user-inputs.mjs",
    "check:openfoam:ready": "node pipeline/openfoam/src/check-openfoam-readiness.mjs",
    "inspect:glb:mcl39": "node pipeline/openfoam/src/inspect-glb-mesh.mjs --file glb_model/f1_2025_mclaren_mcl39.glb",
    "cloudflare:whoami": "wrangler whoami",
    "ingest:openf1:2025": "node pipeline/ingest/src/ingest-openf1-2025-season.mjs",
    "build:openf1:session": "node pipeline/export/src/build-openf1-session-pack.mjs",
    "build:openf1:replay": "node pipeline/export/src/build-openf1-replay-pack.mjs",
    "refresh:showcase:replay": "node pipeline/export/src/build-openf1-replay-pack.mjs --grandPrixSlug abu-dhabi-grand-prix --sessionSlug race && node pipeline/export/src/split-replay-packs.mjs",
    "build:fastf1:replay": "python pipeline/fastf1/build-fastf1-replay-pack.py",
    "build:fastf1:replay:2025": "node pipeline/fastf1/rebuild-fastf1-season.mjs --year 2025",
    "build:fastf1:replay:local": "pip install -r pipeline/fastf1/requirements.txt && python pipeline/fastf1/build-fastf1-replay-pack.py",
    "worker:dev": "npm run dev -w @f1-racing/metadata-api",
    "worker:check": "npm run check -w @f1-racing/metadata-api",
    "worker:deploy": "npm run deploy -w @f1-racing/metadata-api"
  },
  "devDependencies": {
    "wrangler": "^4.39.0"
  },
  "engines": {
    "node": ">=20"
  }
}
